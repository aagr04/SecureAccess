{
  "info": {
    "_postman_id": "5b31b5dc-9b49-4b7c-9ef5-secureaccess",
    "name": "SecureAccess - Login App",
    "description": "Coleccion final para prueba tecnica. Usa endpoints reales del backend Spring Boot.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login ADMIN con username",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"login\": \"{{admin_username}}\",\n  \"password\": \"{{admin_password}}\"\n}" },
            "url": "{{base_url}}/api/auth/login"
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const json = pm.response.json();",
                "if (json.token) pm.environment.set('token', json.token);",
                "if (json.accessToken) pm.environment.set('token', json.accessToken);",
                "if (json.data && json.data.token) pm.environment.set('token', json.data.token);",
                "if (json.idUsuario) pm.environment.set('usuario_id', json.idUsuario);"
              ]
            }
          }]
        },
        {
          "name": "Login USER",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"login\": \"{{user_username}}\",\n  \"password\": \"{{user_password}}\"\n}" },
            "url": "{{base_url}}/api/auth/login"
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const json = pm.response.json();",
                "if (json.token) pm.environment.set('token', json.token);"
              ]
            }
          }]
        },
        {
          "name": "Login con correo",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"login\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}" },
            "url": "{{base_url}}/api/auth/login"
          }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{base_url}}/api/auth/logout" }
        },
        {
          "name": "Recuperar password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"login\": \"{{admin_email}}\"\n}" },
            "url": "{{base_url}}/api/auth/recover"
          }
        }
      ]
    },
    {
      "name": "Usuarios",
      "item": [
        { "name": "Listar usuarios", "request": { "method": "GET", "url": "{{base_url}}/api/usuarios" } },
        { "name": "Usuario autenticado", "request": { "method": "GET", "url": "{{base_url}}/api/usuarios/me" } },
        { "name": "Buscar usuario por ID", "request": { "method": "GET", "url": "{{base_url}}/api/usuarios/{{usuario_id}}" } },
        {
          "name": "Crear usuario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombres\": \"Juan Alberto\",\n  \"apellidos\": \"Piguave Loor\",\n  \"identificacion\": \"1203574901\",\n  \"fechaNacimiento\": \"1999-05-02\",\n  \"username\": \"Juan2024A\",\n  \"password\": \"Clave@123\",\n  \"status\": \"ACTIVO\",\n  \"rol\": \"USER\"\n}" },
            "url": "{{base_url}}/api/usuarios"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.idUsuario) pm.environment.set('usuario_id', json.idUsuario);", "if (json.persona && json.persona.idPersona) pm.environment.set('persona_id', json.persona.idPersona);"] } }]
        },
        {
          "name": "Actualizar usuario",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombres\": \"Juan Alberto\",\n  \"apellidos\": \"Piguave Loor\",\n  \"identificacion\": \"1203574901\",\n  \"fechaNacimiento\": \"1999-05-02\",\n  \"username\": \"Juan2024A\",\n  \"password\": \"\",\n  \"status\": \"ACTIVO\"\n}" },
            "url": "{{base_url}}/api/usuarios/{{usuario_id}}"
          }
        },
        {
          "name": "Actualizar mi perfil",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombres\": \"Persona\",\n  \"apellidos\": \"User\",\n  \"identificacion\": \"0923456789\",\n  \"fechaNacimiento\": \"1995-01-01\",\n  \"username\": \"User1234\",\n  \"password\": \"\"\n}" },
            "url": "{{base_url}}/api/usuarios/me"
          }
        },
        {
          "name": "Cambiar estado",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"ACTIVO\",\n  \"activo\": true\n}" },
            "url": "{{base_url}}/api/usuarios/{{usuario_id}}/estado"
          }
        },
        { "name": "Eliminar usuario logico", "request": { "method": "DELETE", "url": "{{base_url}}/api/usuarios/{{usuario_id}}" } },
        { "name": "Filtrar por identificacion", "request": { "method": "GET", "url": "{{base_url}}/api/usuarios/filter?identificacion=0912345678" } },
        { "name": "Filtrar por username", "request": { "method": "GET", "url": "{{base_url}}/api/usuarios/filter?username=Admin1234" } },
        { "name": "Filtrar por email", "request": { "method": "GET", "url": "{{base_url}}/api/usuarios/filter?email=padmin@mail.com" } }
      ]
    },
    {
