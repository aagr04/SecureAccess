        { "name": "Actualizar rol", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"AUDITOR\"\n}" }, "url": "{{base_url}}/api/roles/{{rol_id}}" } },
