        { "name": "Crear opcion", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Reportes\",\n  \"ruta\": \"/reportes\",\n  \"icono\": \"file-text\",\n  \"orden\": 7\n}" }, "url": "{{base_url}}/api/opciones" } },
        { "name": "Actualizar opcion", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Reportes\",\n  \"ruta\": \"/reportes\",\n  \"icono\": \"file-text\",\n  \"orden\": 7\n}" }, "url": "{{base_url}}/api/opciones/{{opcion_id}}" } },
