        { "name": "Actualizar rol-opcion", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"idRol\": {{rol_id}},\n  \"idOpcion\": {{opcion_id}}\n}" }, "url": "{{base_url}}/api/rol-opciones/{{rol_opcion_id}}" } },
        { "name": "Eliminar rol-opcion logico", "request": { "method": "DELETE", "url": "{{base_url}}/api/rol-opciones/{{rol_opcion_id}}" } }
